{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "verification_result.schema.json",
  "title": "Verification Result",
  "type": "object",
  "required": ["status", "method", "risk_level"],
  "properties": {
    "status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED"] },
    "method": { "type": "string", "enum": ["bundle", "verifier", "tester", "stepgated"] },
    "regressions": { "type": "array", "items": { "type": "string" } },
    "edge_cases_checked": { "type": "array", "items": { "type": "string" } },
    "stress_results": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "risk_level": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
    "fail_reason": { "type": "string" },
    "static_verification": {
      "type": "object",
      "description": "Static (compile + architecture) layer of the Tester Verification Contract. Optional for backward compatibility; required by the contract unless §7 exemption recorded in notes.",
      "properties": {
        "compile_clean": { "type": "boolean" },
        "asmdef_clean": { "type": "boolean" },
        "banned_patterns_found": { "type": "array", "items": { "type": "string" } },
        "burst_compatible": { "type": "boolean" },
        "editor_api_leak": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "runtime_verification": {
      "type": "object",
      "description": "Runtime (executable proof) layer of the Tester Verification Contract. Optional for backward compatibility; required by the contract unless §7 exemption recorded in notes.",
      "properties": {
        "method": { "type": "string", "enum": ["PlayMode", "EditMode", "ReproScene", "Checklist", "None"] },
        "tests_executed": { "type": "integer", "minimum": 0 },
        "tests_passed": { "type": "integer", "minimum": 0 },
        "edge_cases_covered": { "type": "integer", "minimum": 0 },
        "deterministic_runs": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
